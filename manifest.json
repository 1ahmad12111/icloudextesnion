{
  "manifest_version": 3,
  "name": "iCloud Newsletter Sender",
  "version": "1.5.0",
  "description": "Send your newsletter to a list of emails via iCloud Mail, one by one with a delay.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "webNavigation",
    "debugger"
  ],
  "host_permissions": [
    "https://*.icloud.com/*",
    "https://*.icloud-sandbox.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.icloud.com/*",
        "https://*.icloud-sandbox.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
