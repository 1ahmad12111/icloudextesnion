{
  "manifest_version": 3,
  "name": "iCloud Newsletter Sender",
  "version": "1.6.0",
  "description": "Send your newsletter to a list of emails via iCloud Mail, one by one with a delay.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation",
    "debugger",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "https://*.icloud.com/*",
    "https://*.icloud-sandbox.com/*"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.icloud.com/*",
        "https://*.icloud-sandbox.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
