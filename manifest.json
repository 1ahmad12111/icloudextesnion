{
  "manifest_version": 1,
  "name": "iCloud Newsletter Sender",
  "version": "1.0.0",
  "description": "Send your newsletter to a list of emails via iCloud Mail, one by one with a delay.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "https://www.icloud.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.icloud.com/mail/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
